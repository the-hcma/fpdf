#!/usr/bin/env bash
# scripts/on-deploy — repo-specific deploy hook called by scripts/setup-service.
#
# Responsibilities:
#   1. Detect whether the built artefacts are stale relative to the current
#      git HEAD (by comparing dist/.build-rev to HEAD).
#   2. Rebuild via pnpm if stale.
#   3. Print the installed version for operator confirmation.
#
# Exit code contract (consumed by scripts/setup-service):
#   0  — code was rebuilt; setup-service will restart the systemd service.
#   1  — nothing changed; setup-service will skip the restart.
#   2+ — unexpected failure; setup-service aborts (set -euo pipefail).
#
# Worktree behaviour: repo_dir is resolved from BASH_SOURCE[0] so this script
# always operates on the worktree it lives in, regardless of the caller's $PWD.
# This is required for setup-service to correctly deploy feature worktrees.

set -euo pipefail

# True when pnpm-lock.yaml / package.json is newer than node_modules (or missing).
_deploy_pnpm_modules_stale() {
    local repo="$1"
    local lock="$repo/pnpm-lock.yaml"
    local project="$repo/package.json"
    local modules="$repo/node_modules"
    if [[ ! -f "$project" ]]; then
        return 1
    fi
    if [[ ! -d "$modules" ]]; then
        return 0
    fi
    if [[ ! -f "$lock" ]]; then
        return 1
    fi
    local newest_input="$lock"
    local input_mtime modules_mtime lock_mtime
    if [[ -f "$project" ]]; then
        input_mtime="$(stat -c '%Y' "$project")"
        lock_mtime="$(stat -c '%Y' "$lock")"
        if (( input_mtime > lock_mtime )); then
            newest_input="$project"
        fi
    fi
    modules_mtime="$(stat -c '%Y' "$modules")"
    input_mtime="$(stat -c '%Y' "$newest_input")"
    if (( input_mtime > modules_mtime )); then
        return 0
    fi
    return 1
}

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly script_dir
repo_dir="$(cd "$script_dir/.." && pwd)"
readonly repo_dir
# Derive service name from the git remote URL — stable across all worktrees
# regardless of directory name (mirrors setup-service's approach).
gh_remote="$(git -C "$repo_dir" remote get-url origin | sed 's|.*github.com[:/]||;s|\.git$||')"
readonly gh_remote
service_name="${gh_remote##*/}"
readonly service_name

build_rev_file="${repo_dir}/dist/.build-rev"
code_changed=false
deps_changed=false

if _deploy_pnpm_modules_stale "$repo_dir"; then
    echo "📦 pnpm lockfiles newer than node_modules — running pnpm install..."
    pnpm --prefix "${repo_dir}" install --frozen-lockfile
    deps_changed=true
fi

if [[ ! -d "${repo_dir}/dist" || ! -f "$build_rev_file" ]]; then
    echo "🔨 dist/.build-rev not found — running pnpm build..."
    pnpm --prefix "${repo_dir}" build
    code_changed=true
else
    built_rev="$(tr -d '[:space:]' < "$build_rev_file")"
    head_rev="$(git -C "${repo_dir}" rev-parse HEAD)"
    if [[ "$built_rev" != "$head_rev" ]]; then
        echo "🔄 dist built at ${built_rev:0:8}, HEAD is ${head_rev:0:8} — rebuilding..."
        pnpm --prefix "${repo_dir}" build
        code_changed=true
    elif [[ "$deps_changed" == "true" ]]; then
        echo "🔄 dependencies updated — rebuilding..."
        pnpm --prefix "${repo_dir}" build
        code_changed=true
    fi
fi

# Print installed version
pkg_version="$(node -p "require('${repo_dir}/package.json').version" 2>/dev/null || echo "unknown")"
if [[ -f "$build_rev_file" ]]; then
    built_rev="$(tr -d '[:space:]' < "$build_rev_file")"
    echo "📦 ${service_name} v${pkg_version} (commit ${built_rev:0:8})"
else
    echo "📦 ${service_name} v${pkg_version}"
fi

if [[ "$code_changed" == "true" ]]; then
    exit 0
else
    exit 1
fi
