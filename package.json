{
  "name": "fpdf",
  "version": "0.1.0",
  "description": "CLI tool to fill PDF forms via a local browser overlay",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json && pnpm run build:ui",
    "build:ui": "node scripts/build-ui.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc --project tsconfig.web.json --noEmit",
    "lint": "eslint src/ && shellcheck scripts/fpdf",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run --coverage",
    "check": "pnpm run typecheck && pnpm run typecheck:web && pnpm run lint && pnpm run format:check"
  },
  "bin": {
    "fpdf": "dist/cli.js"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "open": "^11.0.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.4"
  }
}
