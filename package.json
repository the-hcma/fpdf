{
  "name": "@the-hcma/fpdf",
  "version": "1.2.4",
  "description": "CLI tool to fill PDF forms via a local browser overlay",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-hcma/fpdf.git"
  },
  "homepage": "https://github.com/the-hcma/fpdf",
  "keywords": [
    "pdf",
    "cli",
    "form-fill",
    "pdf-forms"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json && pnpm run build:ui && git rev-parse HEAD > dist/.build-rev",
    "build:ui": "node scripts/build-ui.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc --project tsconfig.web.json --noEmit",
    "lint": "eslint src/ && find scripts/ -type f ! -name '*.*' | xargs shellcheck",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run --coverage",
    "check": "pnpm run typecheck && pnpm run typecheck:web && pnpm run lint && pnpm run format:check"
  },
  "bin": {
    "fpdf": "dist/cli.js"
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "commander": "15.0.0",
    "express": "^5.2.1",
    "open": "^11.0.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "6.0.227",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/busboy": "^1.5.4",
    "@types/express": "^5.0.6",
    "@types/node": "25.9.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.0",
    "@vitest/coverage-v8": "4.1.8",
    "esbuild": "^0.28.0",
    "eslint": "10.4.1",
    "jiti": "2.7.0",
    "prettier": "3.8.3",
    "tsx": "4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.8"
  }
}
