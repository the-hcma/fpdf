#!/bin/bash

# Setup script for a systemd user service.
# Derives the service name from the repository directory name — no hardcoding.
# Repo-specific build/deploy logic belongs in scripts/on-deploy (optional hook).

set -euo pipefail

# Configuration — resolve to the main worktree so that service name and the
# etc/systemd/ template are always taken from the canonical repo root, not from
# a feature worktree whose directory name would differ from the repo name.
this_worktree="$(git -C "$PWD" rev-parse --show-toplevel)"
readonly this_worktree
repo_dir="$(git -C "$this_worktree" worktree list --porcelain | awk 'NR==1{print $2}')"
readonly repo_dir
service_name="$(basename "$repo_dir")"
readonly service_name
service_filename="${service_name}.service"
readonly service_filename
readonly source_service="${repo_dir}/etc/systemd/${service_filename}"
readonly target_dir="${HOME}/.config/systemd/user"
readonly target_service="${target_dir}/${service_filename}"
log_dir="${HOME}/scratch/${service_name}"
readonly log_dir

# Function to display help
show_help() {
    cat << EOF
${service_name} Setup Utility - Persistent Service

USAGE:
    ./scripts/setup-service [OPTIONS]

DESCRIPTION:
    Configures ${service_name} to run as a persistent background service using systemd.
    Ensures lingering is enabled for the user so the service starts on boot
    and remains active without a login session.

OPTIONS:
    -s, --status
        Check the current configuration status and service health.

    -h, --help
        Display this help message and exit.

    (no options)
        Install or update the systemd service configuration.

EXAMPLES:
    # Set up or update the service
    ./scripts/setup-service

    # Check the current status
    ./scripts/setup-service --status
EOF
    exit 0
}

# Function to check current status
check_status() {
    local all_good=true
    echo "🔍 Verifying ${service_name} service configuration..."
    echo "----------------------------------------"

    # 1. Check service file is installed and up to date
    if [[ ! -f "$target_service" ]]; then
        echo "❌ Service:  Not installed (Run setup to install it)"
        all_good=false
    elif diff --brief <(sed "s|@@REPO_DIR@@|${repo_dir}|g" "$source_service") "$target_service" > /dev/null 2>&1; then
        echo "✅ Service:  Up to date ($target_service)"
    else
        echo "❌ Service:  Outdated (Run setup to update it)"
        all_good=false
    fi

    # 2. Check Lingering
    local current_user
    current_user=$(whoami)
    if loginctl show-user "$current_user" --property=Linger | grep -q "Linger=yes"; then
        echo "✅ Linger:   Enabled for $current_user"
    else
        echo "❌ Linger:   Disabled (Service won't survive reboots!)"
        all_good=false
    fi

    # 3. Check Systemd Service Status
    if systemctl --user is-active "${service_filename}" > /dev/null 2>&1; then
        echo "✅ Active:   Running"
    else
        echo "❌ Active:   Inactive (Stopped)"
        all_good=false
    fi

    if systemctl --user is-enabled "${service_filename}" > /dev/null 2>&1; then
        echo "✅ Enabled:  Auto-start is active"
    else
        echo "❌ Enabled:  Auto-start is disabled"
        all_good=false
    fi

    # 4. Show how the service is invoked
    local unit_text exec_start exec_post args port
    unit_text="$(systemctl --user cat "${service_filename}" 2>/dev/null)"
    exec_start="$(echo "$unit_text" | grep '^ExecStart=' | sed 's/^ExecStart=//')"
    exec_post="$(echo "$unit_text" | grep '^ExecStartPost=' | sed 's/^ExecStartPost=//')"
    if [[ -n "$exec_start" ]]; then
        args="$(echo "$exec_start" | cut -d' ' -f2-)"
        port="$(echo "$args" | grep -oP '(?<=--port )\d+' || true)"
        echo "✅ Starts:    $exec_start"
    fi
    if [[ -n "$exec_post" ]]; then
        echo "✅ Health:    $exec_post"
    fi
    if [[ -n "${port:-}" ]]; then
        echo "   URL:       http://localhost:${port}"
    fi
    echo "   Logs:      tail -f ${log_dir}/${service_name}.log"

    echo "----------------------------------------"
    if $all_good; then
        echo "✨ Everything looks good! ${service_name} is correctly configured."
        return 0
    else
        echo "⚠️  Some issues were found. Run ./scripts/setup-service to fix them."
        return 1
    fi
}

# Handle arguments
if [[ $# -gt 0 ]]; then
    case $1 in
        -h|--help)
            show_help
            ;;
        -s|--status)
            check_status
            exit $?
            ;;
        *)
            echo "❌ Error: Unknown option: $1"
            echo "Run './scripts/setup-service --help' for usage information"
            exit 1
            ;;
    esac
fi

# Main installation flow
echo "Setting up ${service_name} systemd service..."

# 1. Verify source service file exists
if [[ ! -f "$source_service" ]]; then
    echo "❌ Error: Source service file not found at $source_service"
    exit 1
fi

# 2. Ensure target directory exists
mkdir -p "$target_dir"

# 3. Generate service file with repo path substituted
generated=$(sed "s|@@REPO_DIR@@|${repo_dir}|g" "$source_service")
service_changed=true

if [[ -L "$target_service" ]]; then
    echo "🔗 Removing old symlink..."
    rm "$target_service"
elif [[ -f "$target_service" ]]; then
    if diff --brief <(echo "$generated") "$target_service" > /dev/null 2>&1; then
        echo "✅ Service file unchanged: $target_service"
        service_changed=false
    else
        echo "🔄 Service file changed. Updating..."
    fi
fi

if [[ "$service_changed" == "true" ]]; then
    echo "$generated" > "$target_service"
    echo "✅ Service file generated: $target_service (repo: $repo_dir)"
fi

# 4. Create log directory
mkdir -p "$log_dir"
echo "✅ Log directory: $log_dir"

# 5. Enable lingering for the current user
current_user=$(whoami)
echo "👤 Enabling lingering for user: $current_user"
loginctl enable-linger "$current_user"

# 6. Run repo-specific deploy hook if present.
# scripts/on-deploy is an optional executable that handles any build/compile
# steps required before the service can start (e.g. pnpm build, cargo build).
#
# Exit code contract (must be respected by every on-deploy implementation):
#   0  — code was rebuilt; service must be restarted to pick up changes.
#   1  — nothing changed; skip the restart (service is already up to date).
#   2+ — unexpected failure; setup-service will abort (set -euo pipefail).
code_changed=false
if [[ -x "${repo_dir}/scripts/on-deploy" ]]; then
    if "${repo_dir}/scripts/on-deploy"; then
        code_changed=true
    fi
fi

# 7. Reload daemon only if service file changed
if [[ "$service_changed" == "true" ]]; then
    echo "🔄 Reloading systemd user daemon..."
    systemctl --user daemon-reload
fi

# 8. Always ensure the service is enabled and running
systemctl --user enable "$service_filename"
if [[ "$service_changed" == "true" ]]; then
    echo "🔄 Restarting ${service_filename} (config changed)..."
    systemctl --user restart "$service_filename"
elif [[ "$code_changed" == "true" ]]; then
    echo "🔄 Restarting ${service_filename} (code changed)..."
    systemctl --user restart "$service_filename"
elif ! systemctl --user is-active --quiet "$service_filename"; then
    echo "🚀 Starting ${service_filename} (was not running)..."
    systemctl --user start "$service_filename"
else
    echo "⏭️  Service file and code unchanged — no restart needed."
fi

echo ""
echo "✨ ${service_name} service successfully configured!"
check_status
echo "Logs:     tail -f ${log_dir}/${service_name}.log"
echo "----------------------------------------"
