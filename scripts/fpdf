#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly script_dir
root_dir="$(dirname "$script_dir")"
readonly root_dir

# Color only when stderr is a terminal.
if [ -t 2 ]; then
  readonly q=$'\033[0;36m'  # cyan for questions
  readonly r=$'\033[0m'     # reset
else
  readonly q=''
  readonly r=''
fi

# _fpdf_prepend_dir <directory>
# Prepends directory to PATH when it exists and is not already present.
_fpdf_prepend_dir() {
  local -r dir="$1"

  [[ -n "$dir" && -d "$dir" ]] || return 0
  case ":${PATH}:" in
    *":${dir}:"*) return 0 ;;
  esac
  PATH="${dir}:${PATH:-}"
  export PATH
}

_fpdf_prepend_local_bin() {
  if [[ -n "${HOME:-}" && -d "${HOME}/.local/bin" ]]; then
    _fpdf_prepend_dir "${HOME}/.local/bin"
  fi
}

_fpdf_prepend_pnpm_standalone() {
  if command -v pnpm >/dev/null 2>&1; then
    return 0
  fi
  if [[ -n "${HOME:-}" && -x "${HOME}/.local/share/pnpm/pnpm" ]]; then
    _fpdf_prepend_dir "${HOME}/.local/share/pnpm"
  fi
}

# Prefer user-local Node (NVM, fnm, ~/.local/bin) before system nodejs.
# Systemd and non-login shells often omit NVM; login shells already have it.
_fpdf_bootstrap_path() {
  _reload_fnm
  _fpdf_prepend_nvm_default_node
  _fpdf_prepend_local_bin
  _fpdf_prepend_pnpm_standalone
}

# NVM default Node (login shells and cron/systemd often omit ~/.nvm/.../bin).
_fpdf_prepend_nvm_default_node() {
  local nvm_root ver lts_file lts_name latest_ver bin_prefix

  [[ -n "${HOME:-}" ]] || return 0

  nvm_root="${HOME}/.nvm/versions/node"
  [[ -d "$nvm_root" ]] || return 0

  ver=""
  if [[ -f "${HOME}/.nvm/alias/default" ]]; then
    ver="$(tr -d '[:space:]' <"${HOME}/.nvm/alias/default" 2>/dev/null || true)"
  fi

  if [[ "$ver" == lts/* ]]; then
    lts_name="${ver#lts/}"
    lts_file="${HOME}/.nvm/alias/lts/${lts_name}"
    if [[ -f "$lts_file" ]]; then
      ver="$(tr -d '[:space:]' <"$lts_file" 2>/dev/null || true)"
    fi
  fi

  if [[ "$ver" == 'system' ]]; then
    ver=""
  fi

  bin_prefix=""
  if [[ -n "$ver" && -d "${nvm_root}/${ver}/bin" ]]; then
    bin_prefix="${nvm_root}/${ver}/bin"
  else
    latest_ver=""
    latest_ver="$(for d in "$nvm_root"/v*; do
      [[ -d "$d" ]] || continue
      printf '%s\n' "${d##*/}"
    done | sort -V 2>/dev/null | tail -1 || true)"
    if [[ -n "$latest_ver" && -d "${nvm_root}/${latest_ver}/bin" ]]; then
      bin_prefix="${nvm_root}/${latest_ver}/bin"
    fi
  fi

  if [[ -n "$bin_prefix" ]]; then
    _fpdf_prepend_dir "$bin_prefix"
  fi
}

# Load fnm into the current shell (makes fnm-managed node visible in PATH).
# Guard against growing PATH on repeated calls.
_reload_fnm() {
  if [[ ":$PATH:" != *":$HOME/.local/share/fnm:"* && ":$PATH:" != *":$HOME/.fnm:"* ]]; then
    export PATH="$HOME/.local/share/fnm:$HOME/.fnm:$PATH"
  fi
  if command -v fnm &>/dev/null; then
    eval "$(fnm env --shell bash)"
  fi
}

# On macOS, prepend the brew-installed node to PATH if it meets the minimum
# version requirement.  This makes brew the default over any fnm install.
# No-op on Linux or when brew/node are not installed.
_reload_brew_node() {
  command -v brew &>/dev/null || return 0
  local brew_node_bin
  brew_node_bin="$(brew --prefix node 2>/dev/null)/bin"
  [[ -x "${brew_node_bin}/node" ]] || return 0
  local brew_major
  brew_major=$("${brew_node_bin}/node" --version 2>/dev/null | tr -d 'v' | cut -d. -f1)
  [[ -n "$brew_major" && "$brew_major" -ge "${_min_major}" ]] || return 0
  [[ ":$PATH:" == *":${brew_node_bin}:"* ]] && return 0
  export PATH="${brew_node_bin}:$PATH"
}

# Install Node.js via the system package manager.
_node_install_sys() {
  if command -v brew &>/dev/null; then
    brew install node >&2
  elif command -v apt-get &>/dev/null; then
    sudo apt-get install -y nodejs >&2
  elif command -v dnf &>/dev/null; then
    sudo dnf install -y nodejs >&2
  elif command -v yum &>/dev/null; then
    sudo yum install -y nodejs >&2
  elif command -v pacman &>/dev/null; then
    sudo pacman -S --noconfirm nodejs npm >&2
  elif command -v zypper &>/dev/null; then
    sudo zypper install -y nodejs20 >&2
  elif command -v apk &>/dev/null; then
    sudo apk add nodejs npm >&2
  fi
}

# Install (or update) Node.js via fnm. Installs fnm itself if not present.
_node_install_fnm() {
  if ! command -v fnm &>/dev/null; then
    echo "[fpdf] Installing fnm…" >&2
    curl -fsSL https://fnm.vercel.app/install | bash >&2
    export PATH="$HOME/.local/share/fnm:$HOME/.fnm:$PATH"
  fi
  if command -v fnm &>/dev/null; then
    eval "$(fnm env --shell bash)"
    fnm install --lts >&2
    fnm use --lts >&2
    echo "[fpdf] Node.js $(node --version) installed via fnm." >&2
  else
    echo "[fpdf] fnm installed but not in PATH yet. Open a new shell and run:" >&2
    echo "       fnm install --lts && fnm use --lts" >&2
  fi
}

# Remove node_modules, dist, and optionally the fnm-managed Node.js.
_fpdf_clean() {
  _reload_fnm

  if [ -d "$root_dir/node_modules" ]; then
    echo "[fpdf] Removing node_modules…" >&2
    rm -rf "$root_dir/node_modules"
  fi
  if [ -d "$root_dir/dist" ]; then
    echo "[fpdf] Removing dist…" >&2
    rm -rf "$root_dir/dist"
  fi

  local node_path
  node_path=$(command -v node 2>/dev/null || true)
  if [[ -n "$node_path" && "$node_path" == *"fnm"* ]] && command -v fnm &>/dev/null; then
    local node_ver
    node_ver=$(node --version)
    printf '%s[fpdf] Also remove fnm-managed Node.js %s? [Y/n] %s' "$q" "$node_ver" "$r" >&2
    read -r reply || { echo >&2; return; }
    if [[ ! "$reply" =~ ^[Nn] ]]; then
      fnm uninstall "$node_ver" >&2
      echo "[fpdf] Node.js $node_ver removed." >&2
    fi
  fi
  echo "[fpdf] Done." >&2
}

# Handle built-in script flags before any dependency checks.
# --yes: non-interactive mode — accept all prompts automatically (used by systemd service).
_fpdf_yes=0
_remaining_args=()
for _arg in "$@"; do
  if [[ "$_arg" == '--yes' ]]; then
    _fpdf_yes=1
  else
    _remaining_args+=("$_arg")
  fi
done
set -- "${_remaining_args[@]+"${_remaining_args[@]}"}"

# True for systemd --yes, cron, or any context without a controlling terminal on stderr.
_fpdf_non_interactive() {
  [[ "$_fpdf_yes" == '1' ]] || [[ ! -t 2 ]]
}

# pnpm 10+ aborts node_modules purge without a TTY unless CI=true (or confirmModulesPurge).
# Service mode uses frozen-lockfile when a lockfile is present.
_fpdf_pnpm_install() {
  if _fpdf_non_interactive; then
    export CI=true
    if [[ -f "$root_dir/pnpm-lock.yaml" ]]; then
      pnpm --dir "$root_dir" install --frozen-lockfile
    else
      pnpm --dir "$root_dir" install
    fi
  else
    pnpm --dir "$root_dir" install
  fi
}

case "${1:-}" in
  clean)
    # Always handled in bash — clean must work regardless of node/node_modules state.
    _fpdf_bootstrap_path
    _fpdf_clean
    exit 0
    ;;
esac

# Show a numbered install/update menu and run the chosen option.
# When allow_skip=1, the last option is "continue anyway" which sets _fpdf_node_skip=1.
# When allow_skip=0, the last option pauses until the user signals they are ready.
_fpdf_node_skip=0
_offer_node_menu() {
  local -r allow_skip="${1:-0}"

  local sys_label='' sys_ver='' sys_warn=''
  if command -v brew &>/dev/null; then
    sys_label='brew install node'
    sys_ver=$(brew info node 2>/dev/null | grep -oE 'stable [0-9]+\.[0-9]+' | grep -oE '[0-9]+\.[0-9]+' | head -1)
  elif command -v apt-get &>/dev/null; then
    sys_label='sudo apt-get install -y nodejs'
    sys_ver=$(apt-cache show nodejs 2>/dev/null | awk '/^Version:/{print $2; exit}' | grep -oE '^[0-9]+\.[0-9]+')
  elif command -v dnf &>/dev/null; then
    sys_label='sudo dnf install -y nodejs'
    sys_ver=$(dnf info nodejs 2>/dev/null | awk '/^Version/{print $3; exit}' | grep -oE '^[0-9]+\.[0-9]+')
  elif command -v yum &>/dev/null; then
    sys_label='sudo yum install -y nodejs'
    sys_ver=$(yum info nodejs 2>/dev/null | awk '/^Version/{print $3; exit}' | grep -oE '^[0-9]+\.[0-9]+')
  elif command -v pacman &>/dev/null; then
    sys_label='sudo pacman -S --noconfirm nodejs npm'
    sys_ver=$(pacman -Si nodejs 2>/dev/null | awk '/^Version/{print $3; exit}' | grep -oE '^[0-9]+\.[0-9]+')
  elif command -v zypper &>/dev/null; then
    sys_label='sudo zypper install -y nodejs20'
    sys_ver=$(zypper info nodejs20 2>/dev/null | awk '/^Version/{print $3; exit}' | grep -oE '^[0-9]+\.[0-9]+')
  elif command -v apk &>/dev/null; then
    sys_label='sudo apk add nodejs npm'
    sys_ver=$(apk info nodejs 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 | grep -oE '^[0-9]+\.[0-9]+')
  fi
  # If the package manager ships a version below the minimum, drop it as an option.
  if [[ -n "$sys_ver" ]]; then
    local sys_major
    sys_major=$(echo "$sys_ver" | cut -d. -f1)
    if [[ "$sys_major" -lt "$_min_major" ]]; then
      echo "[fpdf] Your package manager ships nodejs v${sys_ver}, which is below the required v${_min_major}." >&2
      sys_label=''
    else
      sys_warn="  (v${sys_ver})"
    fi
  fi

  local n=0 opt_sys=0 opt_fnm=0 opt_last=0
  echo "[fpdf] How would you like to install Node.js (>= ${_min_major})?" >&2
  if [[ -n "$sys_label" ]]; then
    n=$(( n + 1 )); opt_sys=$n
    echo "  $n) $sys_label${sys_warn}" >&2
  fi
  n=$(( n + 1 )); opt_fnm=$n
  echo "  $n) fnm — local, no sudo, installs latest LTS  (~/.local/share/fnm)" >&2
  n=$(( n + 1 )); opt_last=$n
  if [[ "$allow_skip" == '1' ]]; then
    echo "  $n) Continue with current version" >&2
  else
    echo "  $n) I'll do it myself" >&2
  fi
  echo "  0) Exit" >&2

  printf '%s[fpdf] Choice [1]: %s' "$q" "$r" >&2
  read -r reply || { echo >&2; exit 1; }
  [[ -z "$reply" ]] && reply=1

  if [[ "$reply" == '0' ]]; then
    exit 0
  elif [[ "$opt_sys" != '0' && "$reply" == "$opt_sys" ]]; then
    _node_install_sys
  elif [[ "$reply" == "$opt_fnm" ]]; then
    _node_install_fnm
  elif [[ "$reply" == "$opt_last" && "$allow_skip" == '1' ]]; then
    _fpdf_node_skip=1
  elif [[ "$reply" == "$opt_last" ]]; then
    printf '%s[fpdf] Press Enter when Node.js is installed and ready…%s' "$q" "$r" >&2
    read -r _ || true
  else
    echo "[fpdf] Invalid choice." >&2
  fi
}

# Read the minimum required Node.js major version from package.json first —
# _reload_brew_node needs it.  Uses grep so it works before node is installed.
_min_major=$(grep '"node"' "$root_dir/package.json" | grep -oE '[0-9]+' | head -1)
_min_major="${_min_major:-20}"
readonly _min_major

# Load fnm/NVM/local bin, then prefer brew-installed node on macOS if it meets the requirement.
_fpdf_bootstrap_path
_reload_brew_node

# Check that node is available.
while ! command -v node &>/dev/null; do
  echo "[fpdf] 'node' is not installed (required: >= ${_min_major})." >&2
  _offer_node_menu 0
  _fpdf_bootstrap_path
  _reload_brew_node
done

# Check that pnpm is available (node is guaranteed present at this point).
while ! command -v pnpm &>/dev/null; do
  echo "[fpdf] 'pnpm' is not installed (required)." >&2
  if [[ "$_fpdf_yes" == '1' ]]; then
    reply='y'
  else
    printf '%s[fpdf] Install pnpm now via '\''npm install -g pnpm'\''? [Y/n] %s' "$q" "$r" >&2
    read -r reply || { echo >&2; exit 1; }
  fi
  [[ "$reply" =~ ^[Nn] ]] && exit 0
  echo "[fpdf] Installing pnpm…" >&2
  npm install -g pnpm >&2
done

# Check that node_modules exists (pnpm install has been run).
while [ ! -d "$root_dir/node_modules" ]; do
  echo "[fpdf] Dependencies not installed." >&2
  if [[ "$_fpdf_yes" == '1' ]]; then
    reply='y'
  else
    printf '%s[fpdf] Run '\''pnpm install'\'' now? [Y/n] %s' "$q" "$r" >&2
    read -r reply || { echo >&2; exit 1; }
  fi
  [[ "$reply" =~ ^[Nn] ]] && exit 0
  echo "[fpdf] Installing dependencies…" >&2
  if _fpdf_pnpm_install >&2; then
    touch "$root_dir/node_modules"
    echo "[fpdf] Dependencies installed." >&2
  else
    echo "[fpdf] Installation failed — check the output above." >&2
    if _fpdf_non_interactive; then
      exit 1
    fi
  fi
done

# Warn if the running node version is below the minimum required.
_node_major=$(node --version | tr -d 'v' | cut -d. -f1)
while [[ "$_fpdf_node_skip" == '0' && "$_node_major" -lt "$_min_major" ]]; do
  echo "[fpdf] Node $(node --version) is below the required >=v${_min_major}." >&2
  if [[ "$_fpdf_yes" == '1' ]]; then
    _fpdf_node_skip=1
    break
  fi
  _offer_node_menu 1
  _fpdf_bootstrap_path
  _reload_brew_node
  _node_major=$(node --version | tr -d 'v' | cut -d. -f1)
done

# Warn if node_modules is out of sync with package.json or pnpm-lock.yaml.
while [ "$root_dir/package.json" -nt "$root_dir/node_modules" ] || \
      [ "$root_dir/pnpm-lock.yaml" -nt "$root_dir/node_modules" ]; do
  echo "[fpdf] Dependencies may be out of date (package.json or pnpm-lock.yaml has changed since last install)." >&2
  if [[ "$_fpdf_yes" == '1' ]]; then
    reply='y'
  else
    printf '%s[fpdf] Run pnpm install to update? [Y/n] %s' "$q" "$r" >&2
    read -r reply || { echo >&2; exit 1; }
  fi
  [[ "$reply" =~ ^[Nn] ]] && break
  echo "[fpdf] Updating dependencies…" >&2
  if _fpdf_pnpm_install >&2; then
    touch "$root_dir/node_modules"
    echo "[fpdf] Dependencies updated." >&2
  else
    echo "[fpdf] Update failed — check the output above." >&2
    if _fpdf_non_interactive; then
      exit 1
    fi
  fi
done

# Rebuild if any source file is newer than the compiled entry point.
if [ ! -f "$root_dir/dist/cli.js" ] || \
   find "$root_dir/src" -name '*.ts' -newer "$root_dir/dist/cli.js" | grep -q .; then
  echo "[fpdf] source changed — rebuilding…" >&2
  pnpm --dir "$root_dir" run build >&2
fi

exec node "$root_dir/dist/cli.js" "$@"
