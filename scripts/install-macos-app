#!/usr/bin/env bash
# install-macos-app — create fpdf.app and install it to /Applications  (macOS only)
#
# Requires: macOS with Xcode Command Line Tools (xcode-select --install)
#
# Usage:
#   ./scripts/install-macos-app                          # install to /Applications
#   ./scripts/install-macos-app --dest ~/Applications    # install for current user only
#   ./scripts/install-macos-app uninstall                # remove from /Applications
#   ./scripts/install-macos-app uninstall --dest ~/Applications
#
# The app opens a Terminal window and runs `scripts/fpdf --open`, which starts
# the local web server and launches the file picker in your default browser.
# Close the Terminal window to stop the server.
#
# Re-running is a no-op when the installed app is identical to what would be
# built now (same repo path + same icon and AppleScript templates).
# Re-run after moving the repo to update the baked-in path.
set -euo pipefail

if [[ "$(uname)" != "Darwin" ]]; then
  echo "error: install-macos-app only works on macOS." >&2
  exit 1
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly script_dir
repo_dir="$(dirname "$script_dir")"
readonly repo_dir

subcommand=""
dest="/Applications"
while [[ $# -gt 0 ]]; do
  case "$1" in
    uninstall) subcommand="uninstall"; shift ;;
    --dest) dest="$2"; shift 2 ;;
    *) echo "Unknown argument: $1" >&2; exit 1 ;;
  esac
done
readonly dest

readonly app_path="${dest}/fpdf.app"

# ── Uninstall ─────────────────────────────────────────────────────────────────
if [[ "$subcommand" == "uninstall" ]]; then
  if [[ ! -e "$app_path" ]]; then
    echo "Nothing to remove: ${app_path} does not exist."
    exit 0
  fi
  rm -rf "$app_path"
  echo "Removed: ${app_path}"
  exit 0
fi

# Sidecar file inside the bundle storing a SHA-256 of AppleScript + icon source.
# If the hash matches on re-run the installed app is already identical.
readonly stamp_file="${app_path}/Contents/Resources/fpdf-content-hash"

# ── AppleScript source (baked repo path) ─────────────────────────────────────
applescript_content="-- fpdf.app — generated by install-macos-app
-- repo: ${repo_dir}
property repoPath : \"${repo_dir}\"

on run
    tell application \"Terminal\"
        activate
        do script \"cd \" & quoted form of repoPath & \" && ./scripts/fpdf --open\"
    end tell
end run"
readonly applescript_content

# ── Swift icon generator source ───────────────────────────────────────────────
# Draws a crimson rounded-rect with "@#$%" centred (cream background) and a
# muted "pdf" label at the bottom — visually communicates the tool's name.
# Single-quoted so no bash expansion occurs inside the Swift source.
# shellcheck disable=SC2016
readonly icon_gen_src='import AppKit
import CoreText

guard CommandLine.arguments.count > 1 else {
    fputs("Usage: icon-gen <output.png>\n", stderr); exit(1)
}

let size = 1024
let s    = CGFloat(size)
let cs   = CGColorSpaceCreateDeviceRGB()
guard let ctx = CGContext(
    data: nil, width: size, height: size,
    bitsPerComponent: 8, bytesPerRow: 0, space: cs,
    bitmapInfo: CGImageAlphaInfo.premultipliedLast.rawValue
) else { fputs("CGContext failed\n", stderr); exit(1) }

let crimson      = CGColor(red: 0.72, green: 0.07, blue: 0.07, alpha: 1.00)
let cream        = CGColor(red: 0.97, green: 0.95, blue: 0.91, alpha: 1.00)
let mutedCrimson = CGColor(red: 0.72, green: 0.07, blue: 0.07, alpha: 0.35)

// Crimson rounded-rect background
let bgPath = CGPath(roundedRect: CGRect(x: 0, y: 0, width: s, height: s),
                    cornerWidth: 120, cornerHeight: 120, transform: nil)
ctx.setFillColor(crimson); ctx.addPath(bgPath); ctx.fillPath()

// Cream inner document shape
let docPath = CGPath(roundedRect: CGRect(x: 60, y: 60, width: s - 120, height: s - 120),
                     cornerWidth: 80, cornerHeight: 80, transform: nil)
ctx.setFillColor(cream); ctx.addPath(docPath); ctx.fillPath()

// "@#$%" — centred, bold, crimson
let font    = CTFontCreateWithName("Helvetica-Bold" as CFString, 230, nil)
let mainStr = NSAttributedString(string: "@#$%", attributes: [
    .font: font as Any, .foregroundColor: crimson
])
let line       = CTLineCreateWithAttributedString(mainStr)
let bounds     = CTLineGetBoundsWithOptions(line, .useGlyphPathBounds)
ctx.textMatrix = .identity
ctx.textPosition = CGPoint(
    x: (s - bounds.width)  / 2 - bounds.origin.x,
    y: s / 2 - bounds.height / 2 - bounds.origin.y + 40
)
CTLineDraw(line, ctx)

// "pdf" — small, muted, bottom
let smallFont = CTFontCreateWithName("Helvetica-Bold" as CFString, 80, nil)
let pdfStr    = NSAttributedString(string: "pdf", attributes: [
    .font: smallFont as Any, .foregroundColor: mutedCrimson
])
let pdfLine   = CTLineCreateWithAttributedString(pdfStr)
let pdfBounds = CTLineGetBoundsWithOptions(pdfLine, .useGlyphPathBounds)
ctx.textPosition = CGPoint(x: (s - pdfBounds.width) / 2, y: 110)
CTLineDraw(pdfLine, ctx)

guard let cgImage = ctx.makeImage() else { fputs("makeImage failed\n", stderr); exit(1) }
let rep = NSBitmapImageRep(cgImage: cgImage)
rep.size = NSSize(width: size, height: size)
guard let png = rep.representation(using: .png, properties: [:]) else {
    fputs("PNG encode failed\n", stderr); exit(1)
}
do {
    try png.write(to: URL(fileURLWithPath: CommandLine.arguments[1]))
} catch {
    fputs("Write failed: \(error)\n", stderr); exit(1)
}'

# ── Content hash (AppleScript + icon source) ─────────────────────────────────
current_hash="$(printf '%s\n%s' "$applescript_content" "$icon_gen_src" | shasum -a 256 | cut -d' ' -f1)"
readonly current_hash

# Skip reinstall if the installed app is already identical.
if [[ -f "$stamp_file" ]]; then
  stored_hash="$(cat "$stamp_file")"
  if [[ "$stored_hash" == "$current_hash" ]]; then
    echo "Already up-to-date: ${app_path}"
    exit 0
  fi
fi

# ── Build icon ────────────────────────────────────────────────────────────────
if ! command -v swift >/dev/null 2>&1; then
  echo "error: 'swift' not found — install Xcode Command Line Tools: xcode-select --install" >&2
  exit 1
fi

tmpdir="$(mktemp -d /tmp/fpdf_install_XXXXXX)"
readonly tmpdir
trap 'rm -rf "$tmpdir"' EXIT

swift_src="${tmpdir}/icon-gen.swift"
src_png="${tmpdir}/icon_1024.png"
iconset="${tmpdir}/fpdf.iconset"
icns_path="${tmpdir}/fpdf.icns"

printf '%s\n' "$icon_gen_src" > "$swift_src"
swift "$swift_src" "$src_png"

mkdir "$iconset"
sips -z 16  16  "$src_png" --out "${iconset}/icon_16x16.png"      >/dev/null
sips -z 32  32  "$src_png" --out "${iconset}/icon_16x16@2x.png"   >/dev/null
sips -z 32  32  "$src_png" --out "${iconset}/icon_32x32.png"       >/dev/null
sips -z 64  64  "$src_png" --out "${iconset}/icon_32x32@2x.png"   >/dev/null
sips -z 128 128 "$src_png" --out "${iconset}/icon_128x128.png"     >/dev/null
sips -z 256 256 "$src_png" --out "${iconset}/icon_128x128@2x.png" >/dev/null
sips -z 256 256 "$src_png" --out "${iconset}/icon_256x256.png"     >/dev/null
sips -z 512 512 "$src_png" --out "${iconset}/icon_256x256@2x.png" >/dev/null
sips -z 512 512 "$src_png" --out "${iconset}/icon_512x512.png"     >/dev/null
cp "$src_png" "${iconset}/icon_512x512@2x.png"

iconutil -c icns -o "$icns_path" "$iconset"

# ── Compile AppleScript app ───────────────────────────────────────────────────
tmpscript="${tmpdir}/fpdf.applescript"
printf '%s\n' "$applescript_content" > "$tmpscript"

mkdir -p "$dest"
osacompile -o "$app_path" "$tmpscript"

# Replace the default applet icon with ours, then force Finder to re-read the
# bundle so the icon shows immediately without a logout/reboot.
cp "$icns_path" "${app_path}/Contents/Resources/applet.icns"
/System/Library/Frameworks/CoreServices.framework/Versions/A/Frameworks/LaunchServices.framework/Versions/A/Support/lsregister -f "${app_path}"
touch "${app_path}"

# Record hash so future runs can detect whether a reinstall is needed.
echo -n "$current_hash" > "$stamp_file"

echo "Installed: ${app_path}"
echo "Double-click it in Finder (or open \"${app_path}\") to launch fpdf."
