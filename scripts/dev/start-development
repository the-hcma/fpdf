#!/bin/bash
# scripts/dev/start-development - Session initialization and worktree management
set -euo pipefail

# Use the caller's git root to identify the repo, not the script's own location —
# so the script works correctly when called from any repo or subdirectory.
# Resolve the worktree root first (handles being inside a subdirectory), then find
# the primary worktree from there.
this_worktree="$(git -C "$PWD" rev-parse --show-toplevel)"
readonly this_worktree
# Use the primary worktree path, not --show-toplevel which returns the *current*
# worktree root when invoked from inside a linked worktree.
main_repo="$(git -C "$this_worktree" worktree list --porcelain | awk 'NR==1{print $2}')"
readonly main_repo
readonly worktrees_dir="$main_repo/.worktrees"
# Derive repo slug (owner/name) and service name from git remote — no hardcoding.
gh_repo="$(git -C "$main_repo" remote get-url origin | sed 's|.*github.com[:/]||;s|\.git$||')"
readonly gh_repo
service_name="${gh_repo##*/}"
readonly service_name
service_unit="${HOME}/.config/systemd/user/${service_name}.service"
readonly service_unit

# Parse arguments
resume=false
refresh=false
for arg in "$@"; do
    case "$arg" in
        --help)
            echo "Usage: scripts/dev/start-development [--help] [--refresh] [--resume]"
            echo ""
            echo "Options:"
            echo "  --help     Show this help message"
            echo "  --refresh  Pull latest main; run setup-service if not installed, otherwise ensure service is running"
            echo "  --resume   Resume an existing in-progress worktree (or create a new one)"
            exit 0
            ;;
        --refresh) refresh=true ;;
        --resume) resume=true ;;
        *) echo "Unknown argument: $arg" >&2
           echo "Run 'scripts/dev/start-development --help' for usage." >&2
           exit 1 ;;
    esac
done

echo "=========================================="
echo "   $service_name Session Initialization   "
echo "=========================================="

# 1. Clean up stale worktree metadata
echo "Pruning stale worktree metadata..."
git -C "$main_repo" worktree prune

# 2. Check each worktree: remove merged/closed, collect pending ones
echo "Checking for Git worktrees..."

wt_info=$(git -C "$main_repo" worktree list --porcelain)
current_path=""
current_branch=""
pending_worktrees=()

while IFS= read -r line; do
    if [[ "$line" =~ ^worktree\ (.*) ]]; then
        current_path="${BASH_REMATCH[1]}"
        current_branch=""
    elif [[ "$line" =~ ^branch\ refs/heads/(.*) ]]; then
        current_branch="${BASH_REMATCH[1]}"

        if [[ "$current_path" == "$main_repo" ]]; then
            continue
        fi

        echo " - Checking worktree: $current_branch ($current_path)..."

        pr_state=$(timeout 15 gh --repo "$gh_repo" pr view "$current_branch" \
            --json state --template '{{.state}}' 2>/dev/null || echo "NOT_FOUND")

        if [[ "$pr_state" == "MERGED" || "$pr_state" == "CLOSED" ]]; then
            if [[ "$current_path" == "$this_worktree" ]]; then
                echo "   [~] PR is $pr_state but this is the running worktree; skipping removal."
                pending_worktrees+=("$current_path|$current_branch")
                continue
            fi
            echo "   [!] PR is $pr_state. Removing worktree..."
            git -C "$main_repo" worktree remove --force "$current_path" 2>/dev/null || true
            # Best-effort: some files (NFS locks, running scripts) may resist removal.
            # Don't let a partial failure abort the entire session startup.
            rm -rf "$current_path" 2>/dev/null || echo "   [~] Could not fully remove '$current_path' (files may be busy); continuing."
            git -C "$main_repo" worktree prune
            git -C "$main_repo" branch -D "$current_branch" 2>/dev/null || true
        else
            echo "   [+] PR is $pr_state. Keeping worktree."
            pending_worktrees+=("$current_path|$current_branch")
        fi
    fi
done <<< "$wt_info"

# 3. Synchronize Graphite and prune merged branches
echo "Synchronizing Graphite (gt sync -f -d)..."

# Only stash *tracked* changes (ignore untracked files like .vscode/ or .worktrees/
# which cannot be stashed without --include-untracked and would cause stash pop to fail).
has_changes=$(git -C "$main_repo" status --porcelain | grep -v '^??' || true)
stashed=false
if [[ -n "$has_changes" ]]; then
    echo "Stashing local changes in main repo..."
    git -C "$main_repo" stash push --message "start-development: automatic stash before sync"
    stashed=true
fi

(cd "$main_repo" && gt sync -q -f -d)

if [[ "$stashed" == "true" ]]; then
    echo "Restoring local changes in main repo..."
    git -C "$main_repo" stash pop
fi

# 3b. Prune orphaned local branches:
#   - PR is MERGED/CLOSED (remote branch still exists), OR
#   - No PR found but branch is fully merged into main (remote branch already deleted)
echo "Pruning orphaned local branches..."

active_branches=()
while IFS= read -r wt_line; do
    if [[ "$wt_line" =~ ^branch\ refs/heads/(.*) ]]; then
        active_branches+=("${BASH_REMATCH[1]}")
    fi
done <<< "$(git -C "$main_repo" worktree list --porcelain)"

while IFS= read -r branch; do
    [[ "$branch" == "main" ]] && continue
    in_worktree=false
    for ab in "${active_branches[@]}"; do
        [[ "$ab" == "$branch" ]] && in_worktree=true && break
    done
    [[ "$in_worktree" == "true" ]] && continue

    orphan_state=$(timeout 15 gh --repo "$gh_repo" pr view "$branch" \
        --json state --template '{{.state}}' 2>/dev/null || echo "NOT_FOUND")

    if [[ "$orphan_state" == "MERGED" || "$orphan_state" == "CLOSED" ]]; then
        echo "   [!] Deleting $branch (PR: $orphan_state)..."
        git -C "$main_repo" branch -D "$branch" 2>/dev/null || true
    elif [[ "$orphan_state" == "NOT_FOUND" ]]; then
        # Remote branch gone; check if it's fully merged into main locally
        if git -C "$main_repo" branch --merged main | grep -qxF "  $branch"; then
            echo "   [!] Deleting $branch (merged into main, no remote PR)..."
            git -C "$main_repo" branch -D "$branch" 2>/dev/null || true
        else
            echo "   [+] Keeping $branch (unmerged, no remote PR)."
        fi
    else
        echo "   [+] Keeping $branch (PR: $orphan_state)."
    fi
done <<< "$(git -C "$main_repo" branch --format='%(refname:short)')"

# Update main if behind origin and restart service if updated
local_main=$(git -C "$main_repo" rev-parse main)
remote_main=$(git -C "$main_repo" rev-parse origin/main)
if [[ "$local_main" != "$remote_main" ]]; then
    echo "Main is outdated. Pulling latest..."
    git -C "$main_repo" merge --ff-only origin/main
    if [[ -f "$service_unit" ]]; then
        echo "Restarting $service_name service..."
        systemctl --user restart "$service_name"
    fi
fi

echo "=========================================="

# --refresh mode: also ensure service is running (start if stopped), then exit.
# Cleanup (worktree/branch pruning, Graphite sync) has already run above.
if [[ "$refresh" == "true" ]]; then
    if [[ ! -f "$service_unit" ]]; then
        if [[ -x "$main_repo/scripts/setup-service" ]]; then
            echo "Service not installed. Running setup-service..."
            "$main_repo/scripts/setup-service"
        else
            echo "No service unit and no setup-service found; skipping service setup."
        fi
    else
        systemctl --user daemon-reload
        if ! systemctl --user is-active --quiet "$service_name"; then
            echo "Starting $service_name service..."
            systemctl --user start "$service_name"
        fi
    fi
    exit 0
fi

# 4. Determine which worktree to work in
num_pending=${#pending_worktrees[@]}
selected_path=""

if [[ "$resume" == "true" && "$num_pending" -gt 0 ]]; then
    if [[ "$num_pending" -eq 1 ]]; then
        wt_path="${pending_worktrees[0]%%|*}"
        wt_branch="${pending_worktrees[0]##*|}"
        echo "Found 1 pending worktree: $wt_branch"
        read -rp "Resume this worktree? [Y/n] " choice
        if [[ "${choice,,}" != "n" ]]; then
            selected_path="$wt_path"
        fi
    else
        echo "Found $num_pending pending worktrees:"
        for i in "${!pending_worktrees[@]}"; do
            echo "  $((i+1))) ${pending_worktrees[$i]##*|}  (${pending_worktrees[$i]%%|*})"
        done
        echo "  $((num_pending+1))) Start new work"
        echo ""
        read -rp "Choose [1-$((num_pending+1))]: " choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && [[ "$choice" -ge 1 ]] && [[ "$choice" -le "$num_pending" ]]; then
            idx=$((choice - 1))
            selected_path="${pending_worktrees[$idx]%%|*}"
        fi
        # If user chose "new" or entered invalid input, fall through to creation below
    fi
elif [[ "$resume" == "true" && "$num_pending" -eq 0 ]]; then
    echo "No pending worktrees found. Creating a new one..."
fi

# Create a new worktree if nothing was selected (default mode, or user chose new work)
if [[ -z "$selected_path" ]]; then
    echo ""
    read -rp "New stack name (e.g. 'auth-bugfix'): " stack_name

    if [[ -z "$stack_name" ]]; then
        echo "No stack name provided. Exiting." >&2
        exit 1
    fi

    selected_path="$worktrees_dir/${stack_name}-wt"
    branch_name="${stack_name}-wt"

    echo ""
    echo "Creating worktree '$branch_name' at $selected_path..."
    git -C "$main_repo" worktree add -b "$branch_name" "$selected_path" main
    (cd "$selected_path" && gt track --parent main)

    echo ""
    echo "Start your first branch with:"
    echo "  gt create $stack_name/<description> -m 'feat: ...'"
    echo "  gt track --parent main   # reparent directly to main (required for gt submit)"
fi

echo ""
echo "To work on this stack, run:"
echo "  cd $selected_path"
echo "=========================================="
echo "Tip: Use 'gt state' to debug Graphite metadata issues."
echo "    Initialization Complete               "
echo "=========================================="
