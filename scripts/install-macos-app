#!/usr/bin/env bash
# install-macos-app — create fpdf.app and install it to ~/Applications
#
# Usage:
#   ./scripts/install-macos-app
#   ./scripts/install-macos-app --dest /Applications   # install system-wide
#
# The app opens a Terminal window and runs `scripts/fpdf --open`, which starts
# the local web server and launches the file picker in your default browser.
# Close the Terminal window to stop the server.
#
# Re-running is a no-op if the app is already installed for this repo.
# Run again after moving the repo to update the baked-in path.
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_dir="$(dirname "$script_dir")"

dest="${HOME}/Applications"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dest) dest="$2"; shift 2 ;;
    *) echo "Unknown argument: $1" >&2; exit 1 ;;
  esac
done

app_path="${dest}/fpdf.app"
# Sidecar file inside the bundle storing a SHA-256 of the generated AppleScript.
# Captures both the repo path and any template changes; if the hash matches on
# re-run the installed app is already identical and no rebuild is needed.
stamp_file="${app_path}/Contents/Resources/fpdf-content-hash"

# Build the AppleScript content we would install.
applescript_content="-- fpdf.app — generated by install-macos-app
-- repo: ${repo_dir}
property repoPath : \"${repo_dir}\"

on run
    tell application \"Terminal\"
        activate
        do script \"cd \" & quoted form of repoPath & \" && ./scripts/fpdf --open\"
    end tell
end run"

current_hash="$(printf '%s' "$applescript_content" | shasum -a 256 | cut -d' ' -f1)"

# Skip reinstall if the app exists and the content hash matches.
if [[ -f "$stamp_file" ]]; then
  stored_hash="$(cat "$stamp_file")"
  if [[ "$stored_hash" == "$current_hash" ]]; then
    echo "Already up-to-date: ${app_path}"
    exit 0
  fi
fi

# Write the AppleScript to a temp file and compile it.
tmpscript="$(mktemp /tmp/fpdf_app_XXXXXX.applescript)"
trap 'rm -f "$tmpscript"' EXIT

printf '%s\n' "$applescript_content" > "$tmpscript"

mkdir -p "$dest"
osacompile -o "$app_path" "$tmpscript"

# Record the hash so future runs can detect whether a reinstall is needed.
echo -n "$current_hash" > "$stamp_file"

echo "Installed: ${app_path}"
echo "Double-click it in Finder (or open \"${app_path}\") to launch fpdf."
