{
  "name": "fpdf",
  "version": "0.1.0",
  "description": "CLI tool to fill PDF forms via a local browser overlay",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json --noEmit && echo 'typecheck ok'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run --coverage",
    "check": "npm run typecheck && npm run lint && npm run format:check"
  },
  "bin": {
    "fpdf": "dist/cli.js"
  },
  "dependencies": {},
  "devDependencies": {}
}
